# ─── GitHub API ──────────────────────────────────────────────────────────────
# Personal Access Token com permissão "Contents: Read & write" no repositório.
# Gere em: github.com/settings/tokens → Fine-grained tokens → New token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Usuário ou organização dona do repositório (ex.: agenciafg)
GITHUB_OWNER=agenciafg

# Nome do repositório (ex.: component-library)
GITHUB_REPO=component-library

# Branch onde os componentes serão commitados (padrão: main)
GITHUB_BRANCH=main

# ─── Acesso (login) ──────────────────────────────────────────────────────────
# ID de acesso que os colaboradores digitam para entrar. Mantenha secreto.
# Se ficar vazio, o acesso fica liberado (modo aberto) — defina em produção!
ACCESS_ID=000000
